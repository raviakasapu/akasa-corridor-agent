# =============================================================================
# Ākāsā Corridor Agent - Environment Configuration
# =============================================================================

# App Settings
APP_HOST=localhost
APP_PORT=8052
APP_RELOAD=true
DEBUG=true
ENVIRONMENT=development

# =============================================================================
# LLM Provider: AWS Bedrock
# =============================================================================
LLM_GATEWAY=BedrockGateway
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# =============================================================================
# Multi-LLM Strategy
# =============================================================================
# Coordinator + Guardian: Claude Haiku 4.5 (safety-critical, non-fine-tunable)
COORDINATOR_MODEL=global.anthropic.claude-haiku-4-5-20251001-v1:0
GUARDIAN_MODEL=global.anthropic.claude-haiku-4-5-20251001-v1:0
MANAGER_MODEL=global.anthropic.claude-haiku-4-5-20251001-v1:0

# Workers: Qwen 3 VL (tool calling, cost-effective)
WORKER_MODEL=qwen.qwen3-vl-235b-a22b

# Fallback
LLM_MODEL=global.anthropic.claude-haiku-4-5-20251001-v1:0

# =============================================================================
# Features
# =============================================================================
ENABLE_PROMPT_CACHING=true
WS_ENABLED=true
WS_TOKEN=your-ws-token
